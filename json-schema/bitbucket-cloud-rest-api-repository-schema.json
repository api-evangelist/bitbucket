{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/bitbucket/refs/heads/main/json-schema/bitbucket-cloud-rest-api-repository-schema.json",
  "title": "Repository",
  "description": "A Bitbucket Cloud repository.",
  "type": "object",
  "properties": {
    "type": { "type": "string", "description": "The resource type." },
    "uuid": { "type": "string", "description": "The repository UUID." },
    "full_name": { "type": "string", "description": "The full name of the repository (workspace/repo-slug)." },
    "name": { "type": "string", "description": "The name of the repository." },
    "slug": { "type": "string", "description": "The URL-friendly slug." },
    "description": { "type": "string", "description": "The repository description." },
    "is_private": { "type": "boolean", "description": "Whether the repository is private." },
    "created_on": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
    "updated_on": { "type": "string", "format": "date-time", "description": "Last update timestamp." },
    "size": { "type": "integer", "description": "The size of the repository in bytes." },
    "language": { "type": "string", "description": "The primary programming language." },
    "has_issues": { "type": "boolean" },
    "has_wiki": { "type": "boolean" },
    "fork_policy": { "type": "string", "enum": ["allow_forks", "no_public_forks", "no_forks"] },
    "scm": { "type": "string", "enum": ["git", "hg"] },
    "project": { "type": "object", "description": "The project this repository belongs to." },
    "mainbranch": { "type": "object", "properties": { "type": { "type": "string" }, "name": { "type": "string" } } },
    "owner": { "type": "object", "description": "The owner of the repository." }
  }
}
